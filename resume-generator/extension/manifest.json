{
  "manifest_version": 3,
  "name": "Resume Generator",
  "version": "1.0",
  "description": "Extracts info from the current page and asks a native host to generate a resume.",
  "permissions": ["nativeMessaging", "tabs", "scripting", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Resume Generator"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Open the Resume Generator side panel"
    }
  }
}
