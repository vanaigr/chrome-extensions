{
  "manifest_version": 3,
  "name": "Cut the Losses",
  "version": "1.0.0",
  "description": "Striped moving background on inputs with more than 50 characters.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
