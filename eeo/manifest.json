{
  "manifest_version": 3,
  "name": "EEO Autofill",
  "version": "0.1.0",
  "description": "Autofill EEO questions on job application sites with Alt+Space.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "autofill": {
      "suggested_key": {
        "default": "Alt+Space"
      },
      "description": "Autofill EEO questions"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.myworkdayjobs.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
