{
  "manifest_version": 3,
  "name": "Alt Fill",
  "version": "1.0",
  "description": "Alt+click to fill input fields with a predefined value",
  "permissions": ["contextMenus"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["fill.js", "content.js"],
      "all_frames": true
    }
  ]
}
